{
  "agent_runtime": "claude_tui",
  "db_path": "/path/to/goated/goated.db",
  "debug": false,
  "default_timezone": "America/Los_Angeles",
  "gateway": "slack",
  "log_dir": "/path/to/goated/logs",
  "model": "opus",
  "slack": {
    "channel_id": "YOUR_SLACK_CHANNEL_ID"
  },
  "workspace_dir": "/path/to/goated/workspace"
}
